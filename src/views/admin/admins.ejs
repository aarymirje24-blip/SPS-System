<%- include('../partials/admin-sidebar', { title, user, currentPath }) %>
<div class="card">
    <h2 style="margin-bottom: 1rem;">Manage Admins & Roles</h2>
    <table style="width:100%; border-collapse:collapse;">
        <thead>
            <tr style="text-align:left; border-bottom: 2px solid var(--border);">
                <th style="padding:0.75rem;">Name</th>
                <th>Email</th>
                <th>Current Role</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
        <% users.forEach(function(u) { %>
            <tr style="border-bottom: 1px solid var(--border);">
                <td style="padding:0.75rem;"><%= u.full_name %></td>
                <td><%= u.email %></td>
                <td>
                    <% 
                        let roleClass = 'badge-role-user';
                        if (u.role === 'super_admin') roleClass = 'badge-role-super';
                        else if (u.role === 'admin') roleClass = 'badge-role-admin';
                    %>
                    <span class="badge <%= roleClass %>" style="padding: 0.25rem 0.75rem;">
                        <%= u.role %>
                    </span>
                </td>
                <td>
                    <% if (u.id !== user.id && u.role !== 'super_admin') { %>
                        <% if (u.role === 'user') { %>
                            <button class="role-change-btn btn" style="font-size:0.75rem;" data-user-id="<%= u.id %>" data-new-role="admin">Promote to Admin</button>
                        <% } else if (u.role === 'admin') { %>
                            <button class="role-change-btn btn btn-outline" style="font-size:0.75rem;" data-user-id="<%= u.id %>" data-new-role="user">Demote to User</button>
                        <% } %>
                    <% } else { %>
                        <span style="color:var(--text-muted); font-size:0.75rem;">—</span>
                    <% } %>
                </td>
            </tr>
        <% }); %>
        </tbody>
    </table>
</div>
<%- include('../partials/admin-footer') %>
