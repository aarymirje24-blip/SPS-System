<%- include('../../partials/header', { title, user, currentPath }) %>
<div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem;">
    <h2>All Organisation Files</h2>
</div>

<div class="card" style="padding: 0;">
    <table style="margin-top: 0;">
        <thead>
            <tr>
                <th>File Name</th>
                <th>Owner</th>
                <th>Size</th>
                <th>Uploaded</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            <% if (files && files.length > 0) { %>
                <% files.forEach(function(file) { %>
                    <tr>
                        <td>
                            <a href="/files/<%= file.id %>" style="display: flex; align-items: center; gap: 0.5rem; text-decoration: none; color: var(--primary); font-weight: 500;">
                                <i data-lucide="file" style="width: 16px; height: 16px;"></i>
                                <%= file.original_name %>
                            </a>
                        </td>
                        <td><%= file.uploader_name %></td>
                        <td style="color: var(--text-muted); font-size: 0.875rem;"><%= (file.size_bytes / 1024).toFixed(1) %> KB</td>
                        <td style="color: var(--text-muted); font-size: 0.875rem;"><%= new Date(file.created_at).toLocaleDateString() %></td>
                        <td>
                            <button class="delete-file-btn btn btn-danger" style="padding: 0.25rem 0.5rem;" data-file-id="<%= file.id %>"><i data-lucide="trash-2" style="width: 16px; height: 16px;"></i></button>
                        </td>
                    </tr>
                <% }); %>
            <% } else { %>
                <tr><td colspan="5" style="text-align: center; color: var(--text-muted);">No files found.</td></tr>
            <% } %>
        </tbody>
    </table>
</div>

<% if (pagination.totalPages > 1) { %>
    <div class="pagination" style="margin-top: 2rem; display: flex; justify-content: center; gap: 0.5rem;">
      <% if (pagination.hasPrev) { %><a href="<%= pagination.prevUrl %>" class="btn btn-outline">← Previous</a><% } %>
      <% pagination.pages.forEach(p => { %>
        <a href="<%= p.url %>" class="btn <%= p.isCurrent ? '' : 'btn-outline' %>"><%= p.number %></a>
      <% }) %>
      <% if (pagination.hasNext) { %><a href="<%= pagination.nextUrl %>" class="btn btn-outline">Next →</a><% } %>
    </div>
<% } %>
<%- include('../../partials/footer') %>
