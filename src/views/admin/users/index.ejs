<%- include('../../partials/admin-sidebar', { title: 'Manage Users', user, currentPath }) %>
    <div class="toolbar">
      <form action="/admin/users" method="GET" class="search-wrap" style="flex: 1;">
        <i class="fas fa-search"></i>
        <input class="search-input" name="search" type="text" placeholder="Search by name or email">
        <select name="role" class="search-input" style="max-width: 200px; margin-left: 10px;">
            <option value="">All Roles</option>
            <option value="user">User</option>
            <option value="admin">Admin</option>
            <option value="super_admin">Super Admin</option>
        </select>
        <button type="submit" class="btn" style="margin-left: 10px;">Filter</button>
      </form>
      <button id="invite-btn" class="btn" style="background: var(--primary); color: white;"><i class="fas fa-user-plus"></i> Invite User</button>
    </div>

    <div class="table-card">
      <div class="table-card-header">
        <span class="table-card-title"><i class="fas fa-users"></i> User Directory</span>
        <span class="record-count"><%= total %> entries</span>
      </div>
      <table>
        <thead>
          <tr>
            <th>User</th>
            <th>Role</th>
            <th>Status</th>
            <th>Last Login</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
            <% if (users && users.length > 0) { %>
                <% users.forEach(function(u) { %>
                  <tr>
                    <td>
                      <div class="user-cell">
                        <div class="avatar avatar-blue"><%= u.full_name ? u.full_name.charAt(0).toUpperCase() : 'U' %></div>
                        <div>
                          <div class="user-name"><%= u.full_name %></div>
                          <div style="font-size: 12px; color: #64748b;"><%= u.email %></div>
                        </div>
                      </div>
                    </td>
                    <td>
                        <% if (u.role === 'super_admin' || u.role === 'admin') { %>
                            <span class="action-badge action-upload"><i class="fas fa-shield-alt"></i> <%= u.role %></span>
                        <% } else { %>
                            <span class="action-badge action-default"><i class="fas fa-user"></i> <%= u.role %></span>
                        <% } %>
                    </td>
                    <td>
                        <% if (u.is_active) { %>
                            <span class="action-badge action-share"><i class="fas fa-check-circle"></i> Active</span>
                        <% } else { %>
                            <span class="action-badge action-delete"><i class="fas fa-times-circle"></i> Inactive</span>
                        <% } %>
                    </td>
                    <td><span class="timestamp"><%= u.last_login_at ? new Date(u.last_login_at).toLocaleDateString() : 'Never' %></span></td>
                    <td>
                        <a href="/admin/users/<%= u.id %>" class="btn" style="padding: 0.25rem 0.5rem; font-size: 0.75rem;">Manage</a>
                    </td>
                  </tr>
                <% }); %>
            <% } else { %>
                <tr>
                    <td colspan="5" style="text-align: center; color: #64748b; padding: 20px;">No users found.</td>
                </tr>
            <% } %>
        </tbody>
      </table>
    </div>

    <% if (pagination && pagination.totalPages > 1) { %>
        <div class="pagination" style="margin-top: 2rem; display: flex; justify-content: center; gap: 0.5rem;">
          <% if (pagination.hasPrev) { %><a href="<%= pagination.prevUrl %>" class="page-link">← Previous</a><% } %>
          <% pagination.pages.forEach(p => { %>
            <a href="<%= p.url %>" class="page-link <%= p.isCurrent ? 'active' : '' %>"><%= p.number %></a>
          <% }) %>
          <% if (pagination.hasNext) { %><a href="<%= pagination.nextUrl %>" class="page-link">Next →</a><% } %>
        </div>
    <% } %>

<!-- Invite Modal -->
<div id="invite-modal" class="modal">
    <div class="modal-content">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem;">
            <h3>Invite New User</h3>
            <button id="close-invite-modal" style="background:none;border:none;cursor:pointer;"><i class="fas fa-times"></i></button>
        </div>
        <form id="invite-form">
            <div class="form-group">
                <label>Email Address</label>
                <input type="email" id="invite-email" required class="search-input" style="width: 100%; box-sizing: border-box; padding: 8px;">
            </div>
            <div class="form-group" style="margin-top: 15px;">
                <label>Role</label>
                <select id="invite-role" class="search-input" style="width: 100%; box-sizing: border-box; padding: 8px;">
                    <option value="user">User</option>
                    <option value="admin">Admin</option>
                </select>
            </div>
            <button type="submit" class="btn" style="background: var(--primary); color: white; width: 100%; margin-top: 15px;">Send Invitation</button>
        </form>
    </div>
</div>

<%- include('../../partials/admin-footer') %>
