<%- include('../../partials/admin-sidebar', { title: 'Manage Users', user, currentPath }) %>
<div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem;">
    <h2>Manage Users</h2>
    <button id="invite-btn" class="btn"><i data-lucide="user-plus" style="width: 16px; height: 16px; vertical-align: middle;"></i> Invite User</button>
</div>

<div class="card" style="margin-bottom: 1rem; padding: 1rem;">
    <form action="/admin/users" method="GET" style="display: flex; gap: 1rem;">
        <input type="text" name="search" placeholder="Search by name or email" style="flex: 1; padding: 0.5rem; border: 1px solid var(--border); border-radius: 0.375rem;">
        <select name="role" style="padding: 0.5rem; border: 1px solid var(--border); border-radius: 0.375rem;">
            <option value="">All Roles</option>
            <option value="user">User</option>
            <option value="admin">Admin</option>
            <option value="super_admin">Super Admin</option>
        </select>
        <button type="submit" class="btn">Filter</button>
    </form>
</div>

<div class="card" style="padding: 0;">
    <table style="margin-top: 0;">
        <thead>
            <tr>
                <th>Name</th>
                <th>Email</th>
                <th>Role</th>
                <th>Status</th>
                <th>Last Login</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            <% if (users && users.length > 0) { %>
                <% users.forEach(function(u) { %>
                    <tr>
                        <td style="font-weight: 500;"><%= u.full_name %></td>
                        <td><%= u.email %></td>
                        <td>
                            <% if (u.role === 'super_admin' || u.role === 'admin') { %>
                                <span class="badge badge-admin"><%= u.role %></span>
                            <% } else { %>
                                <span class="badge" style="background: var(--border); color: var(--text-main);"><%= u.role %></span>
                            <% } %>
                        </td>
                        <td>
                            <% if (u.is_active) { %>
                                <span class="badge" style="background: #D1FAE5; color: #065F46;">Active</span>
                            <% } else { %>
                                <span class="badge" style="background: #FEE2E2; color: #991B1B;">Inactive</span>
                            <% } %>
                        </td>
                        <td style="color: var(--text-muted); font-size: 0.875rem;"><%= u.last_login_at ? new Date(u.last_login_at).toLocaleDateString() : 'Never' %></td>
                        <td>
                            <a href="/admin/users/<%= u.id %>" class="btn" style="padding: 0.25rem 0.5rem; font-size: 0.75rem;">Manage</a>
                        </td>
                    </tr>
                <% }); %>
            <% } else { %>
                <tr><td colspan="6" style="text-align: center; color: var(--text-muted);">No users found.</td></tr>
            <% } %>
        </tbody>
    </table>
</div>

<% if (pagination.totalPages > 1) { %>
    <div class="pagination" style="margin-top: 2rem; display: flex; justify-content: center; gap: 0.5rem;">
      <% if (pagination.hasPrev) { %><a href="<%= pagination.prevUrl %>" class="btn btn-outline">← Previous</a><% } %>
      <% pagination.pages.forEach(p => { %>
        <a href="<%= p.url %>" class="btn <%= p.isCurrent ? '' : 'btn-outline' %>"><%= p.number %></a>
      <% }) %>
      <% if (pagination.hasNext) { %><a href="<%= pagination.nextUrl %>" class="btn btn-outline">Next →</a><% } %>
    </div>
<% } %>

<!-- Invite Modal -->
<div id="invite-modal" class="modal">
    <div class="modal-content">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem;">
            <h3>Invite New User</h3>
            <button id="close-invite-modal" style="background:none;border:none;cursor:pointer;"><i data-lucide="x"></i></button>
        </div>
        <form id="invite-form">
            <div class="form-group">
                <label>Email Address</label>
                <input type="email" id="invite-email" required>
            </div>
            <div class="form-group">
                <label>Role</label>
                <select id="invite-role">
                    <option value="user">User</option>
                    <option value="admin">Admin</option>
                </select>
            </div>
            <button type="submit" class="btn" style="width: 100%;">Send Invitation</button>
        </form>
    </div>
</div>
<%- include('../../partials/admin-footer') %>
