<%- include('../../partials/admin-sidebar', { title: 'User Details', user, currentPath }) %>
<div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem;">
    <h2>User Details: <%= targetUser.full_name %></h2>
    <a href="/admin/users" class="btn" style="background: var(--border); color: var(--text-main);">Back to Users</a>
</div>

<div class="grid" style="grid-template-columns: 1fr 1fr; gap: 2rem;">
    <div class="card">
        <h3>Information</h3>
        <br>
        <p><strong>Email:</strong> <%= targetUser.email %></p>
        <p><strong>Role:</strong>
            <% if (user.role === 'super_admin' && targetUser.id !== user.id) { %>
                <select id="role-select" data-user-id="<%= targetUser.id %>" style="padding: 0.5rem; border: 1px solid var(--border); border-radius: 0.375rem;">
                    <option value="user" <%= targetUser.role === 'user' ? 'selected' : '' %>>User</option>
                    <option value="admin" <%= targetUser.role === 'admin' ? 'selected' : '' %>>Admin</option>
                    <option value="super_admin" <%= targetUser.role === 'super_admin' ? 'selected' : '' %>>Super Admin</option>
                </select>
            <% } else { %>
                <%= targetUser.role %>
            <% } %>
        </p>
        <p><strong>Status:</strong> <%= targetUser.is_active ? 'Active' : 'Inactive' %></p>
        <p><strong>Failed Logins:</strong> <%= targetUser.failed_login_attempts %></p>
    </div>
    <div class="card">
        <h3>Actions</h3>
        <br>
        <button id="admin-reset-pwd-btn" class="btn" style="margin-bottom: 1rem; width: 100%;" 
                data-user-id="<%= targetUser.id %>" 
                data-user-name="<%= targetUser.full_name %>">Send Password Reset Link</button>
        <% if (user.role === 'super_admin' && targetUser.id !== user.id) { %>
            <div style="border-top: 1px solid var(--border); margin: 1rem 0; padding-top: 1rem;">
                <button id="toggle-active-btn" class="btn <%= targetUser.is_active ? 'btn-danger' : '' %>" style="width: 100%;" data-user-id="<%= targetUser.id %>" data-current-state="<%= targetUser.is_active %>">
                    <%= targetUser.is_active ? 'Deactivate User' : 'Activate User' %>
                </button>
            </div>
        <% } %>
    </div>
</div>

<div class="card" style="margin-top: 2rem;">
    <h3>Files Owned</h3>
    <br>
    <p>View all files uploaded by this user.</p>
    <br>
    <a href="/admin/files?uploaded_by=<%= targetUser.id %>" class="btn" style="display: inline-block;">View Files by This User →</a>
</div>
<%- include('../../partials/admin-footer') %>
