<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title><%= title %> — SecureShare</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
    <div class="auth-container">
        <div class="card auth-card">
            <h2>Accept Invitation</h2>
            <p style="color:var(--text-muted);font-size:0.875rem;margin-bottom:1rem;">Complete your account setup to join your organisation.</p>
            <form id="accept-invite-form">
                <input type="hidden" id="token" value="<%= token %>">
                <div class="form-group">
                    <label>Full Name</label>
                    <input type="text" id="full_name" required>
                </div>
                <div class="form-group">
                    <label>Password</label>
                    <input type="password" id="password" required>
                </div>
                <div class="form-group">
                    <label>Confirm Password</label>
                    <input type="password" id="confirm_password" required>
                </div>
                <button type="submit" class="btn" style="width:100%;">Join Organisation</button>
            </form>
        </div>
    </div>
    <div id="toast-container"></div>
    <script src="/js/main.js"></script>
</body>
</html>
