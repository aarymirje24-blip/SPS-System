<%- include('../partials/header', { title, user, currentPath }) %>
<div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem;">
    <h2><%= folder.name %></h2>
</div>

<% if (breadcrumb && breadcrumb.length > 0) { %>
    <div style="margin-bottom: 1rem; font-size: 0.875rem;">
        <a href="/files" style="text-decoration: none; color: var(--primary);">Root</a>
        <% breadcrumb.forEach(function(crumb) { %>
            <span style="color: var(--text-muted); margin: 0 0.25rem;">/</span>
            <a href="/folders/<%= crumb.id %>" style="text-decoration: none; color: var(--primary);"><%= crumb.name %></a>
        <% }); %>
    </div>
<% } %>

<% if (subFolders && subFolders.length > 0) { %>
    <h4 style="margin-bottom: 0.5rem; color: var(--text-muted);">Folders</h4>
    <div class="grid grid-cols-4" style="margin-bottom: 2rem;">
        <% subFolders.forEach(function(sub) { %>
            <a href="/folders/<%= sub.id %>" class="folder-card">
                <div style="display: flex; align-items: center; gap: 0.5rem;">
                    <i data-lucide="folder" style="color: #FCD34D;"></i>
                    <span style="font-weight: 500; font-size: 0.875rem;"><%= sub.name %></span>
                </div>
            </a>
        <% }); %>
    </div>
<% } %>

<h4 style="margin-bottom: 0.5rem; color: var(--text-muted);">Files</h4>
<div class="grid grid-cols-4">
    <% if (files && files.length > 0) { %>
        <% files.forEach(function(file) { %>
            <div class="file-card" style="position: relative;">
                <a href="/files/<%= file.id %>" style="text-decoration: none; color: inherit; display: block;">
                    <div style="margin-bottom: 0.5rem;"><i data-lucide="file" style="color: var(--primary);"></i></div>
                    <div style="font-weight: 500; font-size: 0.875rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;"><%= file.original_name %></div>
                    <div style="color: var(--text-muted); font-size: 0.75rem;"><%= (file.size_bytes / 1024).toFixed(1) %> KB • <%= new Date(file.created_at).toLocaleDateString() %></div>
                </a>
            </div>
        <% }); %>
    <% } else { %>
        <p style="color: var(--text-muted); grid-column: span 4;">No files found in this folder.</p>
    <% } %>
</div>
<%- include('../partials/footer') %>
