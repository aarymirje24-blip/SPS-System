<%- include('../partials/header', { title, user, currentPath }) %>
<div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem;">
    <h2><%= folder.name %></h2>
    <div style="display: flex; gap: 1rem;">
        <button id="new-folder-btn" class="btn" data-parent-id="<%= folder.id %>"><i data-lucide="folder-plus" style="width: 16px; height: 16px; vertical-align: middle;"></i> New Folder</button>
        <button id="upload-btn" class="btn"><i data-lucide="upload" style="width: 16px; height: 16px; vertical-align: middle;"></i> Upload File</button>
    </div>
</div>

<% if (breadcrumb && breadcrumb.length > 0) { %>
    <div style="margin-bottom: 1rem; font-size: 0.875rem;">
        <a href="/files" style="text-decoration: none; color: var(--primary);">Root</a>
        <% breadcrumb.forEach(function(crumb) { %>
            <span style="color: var(--text-muted); margin: 0 0.25rem;">/</span>
            <a href="/folders/<%= crumb.id %>" style="text-decoration: none; color: var(--primary);"><%= crumb.name %></a>
        <% }); %>
    </div>
<% } %>

<% if (subFolders && subFolders.length > 0) { %>
    <h4 style="margin-bottom: 0.5rem; color: var(--text-muted);">Folders</h4>
    <div class="grid grid-cols-4" style="margin-bottom: 2rem;">
        <% subFolders.forEach(function(sub) { %>
            <div class="folder-card" style="position:relative;">
                <a href="/folders/<%= sub.id %>" style="text-decoration: none; color: inherit; display: block;">
                    <div style="display: flex; align-items: center; gap: 0.5rem;">
                        <i data-lucide="folder" style="color: #FCD34D;"></i>
                        <span style="font-weight: 500; font-size: 0.875rem;"><%= sub.name %></span>
                    </div>
                </a>
                <div style="position:absolute;top:0.5rem;right:0.5rem;">
                    <button class="folder-menu-btn" data-folder-id="<%= sub.id %>" data-folder-name="<%= sub.name %>"
                      style="background:none;border:none;cursor:pointer;font-size:1.25rem;line-height:1;" 
                      onclick="event.preventDefault();toggleFolderMenu(this)">⋮</button>
                    <div class="folder-dropdown" style="display:none;position:absolute;right:0;top:100%;background:white;border:1px solid var(--border);border-radius:0.375rem;box-shadow:0 4px 6px rgba(0,0,0,0.1);z-index:10;width:120px;">
                      <button class="rename-folder-btn" data-folder-id="<%= sub.id %>" data-folder-name="<%= sub.name %>"
                        style="display:block;width:100%;padding:0.5rem 1rem;text-align:left;background:none;border:none;cursor:pointer;font-size:0.875rem;">Rename</button>
                      <button class="delete-folder-btn" data-folder-id="<%= sub.id %>"
                        style="display:block;width:100%;padding:0.5rem 1rem;text-align:left;background:none;border:none;cursor:pointer;font-size:0.875rem;color:var(--danger);">Delete</button>
                    </div>
                </div>
            </div>
        <% }); %>
    </div>
<% } %>

<h4 style="margin-bottom: 0.5rem; color: var(--text-muted);">Files</h4>
<div class="grid grid-cols-4">
    <% if (files && files.length > 0) { %>
        <% files.forEach(function(file) { %>
            <div class="file-card" style="position: relative;">
                <a href="/files/<%= file.id %>" style="text-decoration: none; color: inherit; display: block;">
                    <div style="margin-bottom: 0.5rem;"><i data-lucide="file" style="color: var(--primary);"></i></div>
                    <div style="font-weight: 500; font-size: 0.875rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;"><%= file.original_name %></div>
                    <div style="color: var(--text-muted); font-size: 0.75rem;"><%= (file.size_bytes / 1024).toFixed(1) %> KB • <%= new Date(file.created_at).toLocaleDateString() %></div>
                </a>
            </div>
        <% }); %>
    <% } else { %>
        <p style="color: var(--text-muted); grid-column: span 4;">No files found in this folder.</p>
    <% } %>
</div>
<%- include('../partials/footer') %>
